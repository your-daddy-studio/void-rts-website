---
// Dynamic devlog post page — renders any devlog entry from the content collection
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Tell Astro to generate a page for every devlog entry
// Strip the .md extension from the id so URLs are clean: /devlog/001-v0040-foundation/
export async function getStaticPaths() {
  const devlogs = await getCollection('devlog');
  return devlogs.map((entry) => ({
    params: { id: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

function formatDate(dateStr: string) {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <div class="container">

    <a href={`${base}/devlog/`} class="back-link">{"< All devlog entries"}</a>

    <div class="post-meta">
      <span>{formatDate(entry.data.date)}</span>
      {entry.data.version && (
        <span class="version-badge">{entry.data.version}</span>
      )}
    </div>

    <h1 style="margin-bottom: 2rem;">{entry.data.title}</h1>

    <div class="prose prose--devlog">
      <Content />
    </div>

  </div>
</BaseLayout>
