---
// Devlog index — shows all devlog entries, newest first
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allDevlogs = await getCollection('devlog');
// Sort newest first
const devlogs = allDevlogs.sort((a, b) => b.data.date.localeCompare(a.data.date));

function formatDate(dateStr: string) {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<BaseLayout
  title="Devlog"
  description="Development log for VOID RTS — updates on what's been built, what changed, and what's coming next."
>
  <div class="container">

    <div class="page-header">
      <h1>Devlog</h1>
      <p>Development updates — what got built, what changed, what broke, what's next.</p>
    </div>

    {devlogs.length === 0 && (
      <p style="color: var(--text-dim);">No entries yet. Check back soon.</p>
    )}

    <div class="card-list">
      {devlogs.map((entry) => (
        <a href={`${base}/devlog/${entry.id.replace(/\.md$/, '')}/`} class="card">
          <div class="card-meta">
            <span>{formatDate(entry.data.date)}</span>
            {entry.data.version && (
              <span class="card-version">{entry.data.version}</span>
            )}
          </div>
          <p class="card-title">{entry.data.title}</p>
          <p class="card-summary">{entry.data.summary}</p>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
