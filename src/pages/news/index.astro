---
// News index — shows all published articles, newest first
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const allNews = await getCollection('news', ({ data }) => data.published);
const news = allNews.sort((a, b) => b.data.date.localeCompare(a.data.date));

function formatDate(dateStr: string) {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<BaseLayout
  title="News"
  description="News and articles about VOID RTS — announcements, deep dives, and development updates."
>
  <div class="container">

    <div class="page-header">
      <h1>News</h1>
      <p>Announcements, articles, and longer reads about VOID RTS.</p>
    </div>

    {news.length === 0 && (
      <p style="color: var(--text-dim);">No articles yet. Check back soon.</p>
    )}

    <div class="card-list card-list--grid">
      {news.map((entry) => (
        <a href={`${base}/news/${entry.id.replace(/\.md$/, '')}/`} class="card">
          {entry.data.heroImage && (
            <img
              src={`${base}/images/${entry.data.heroImage}`}
              alt={entry.data.title}
              class="card-thumbnail"
            />
          )}
          <div class="card-meta">
            <span>{formatDate(entry.data.date)}</span>
          </div>
          <p class="card-title">{entry.data.title}</p>
          <p class="card-summary">{entry.data.summary}</p>
        </a>
      ))}
    </div>

  </div>
</BaseLayout>
