---
// Strona główna (Polish home page)
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Grab the most recent Polish devlog entry to show as preview
const allDevlogs = await getCollection('devlog-pl');
const sortedDevlogs = allDevlogs.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latestDevlog = sortedDevlogs[0];

// Grab the most recent Polish news article
const allNews = await getCollection('news-pl', ({ data }) => data.published);
const sortedNews = allNews.sort((a, b) => b.data.date.localeCompare(a.data.date));
const latestNews = sortedNews[0];

// Format a date string like "2026-03-02" to "2 marca 2026" (Polish locale)
function formatDate(dateStr: string) {
  return new Date(dateStr + 'T00:00:00').toLocaleDateString('pl-PL', {
    year: 'numeric', month: 'long', day: 'numeric'
  });
}
---

<BaseLayout
  lang="pl"
  title="Strona Główna"
  description="VOID RTS — kosmiczny RTS w przeglądarce, gdzie wszystko jest zbudowane z wokseli. Dowódź flotami, pozyskuj surowce i walcz przez mgłę wojny."
>

  <!-- Sekcja hero ---------------------------------------->
  <section class="hero container">
    <div class="hero-badge">Projekt w Budowie</div>
    <h1 class="hero-title">VOID RTS</h1>
    <p class="hero-subtitle">Woksylowy RTS &mdash; Retro Korzenie, Nowy Świat</p>
    <p class="hero-desc">
      Budowanie woksylowej gry strategii czasu rzeczywistego od podstaw &mdash; klimat głębokiego kosmosu,
      zniszczalność wszystkiego i retro-arcadowy styl owinięty w coś nowoczesnego.
      Zero doświadczenia w gamedevie. Nie mam pojęcia co robię. Zobaczymy, jak to wyjdzie.
    </p>
  </section>

  <div class="container">
    <hr class="scanline" />

    <!-- Sekcja kluczowych funkcji ----------------------->
    <section>
      <div class="section-header">
        <h2>// O co w tym chodzi</h2>
      </div>
      <div class="features-grid">

        <!-- 1. Woksylowy RTS -->
        <div class="feature-item">
          <div class="feature-icon" aria-hidden="true">
            <svg class="ficon ficon--voxel" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <g fill="#44aaff">
                <rect x="12" y="8" width="24" height="4"/>
                <rect x="12" y="12" width="24" height="4"/>
                <rect x="12" y="16" width="24" height="4"/>
                <rect x="12" y="20" width="24" height="4"/>
                <rect x="12" y="24" width="24" height="4"/>
                <rect x="12" y="28" width="24" height="4"/>
              </g>
              <rect x="32" y="12" width="4" height="20" fill="#1a6699"/>
              <rect x="16" y="28" width="20" height="4" fill="#1a6699"/>
              <rect x="12" y="8" width="4" height="4" fill="#66ccff"/>
              <rect x="16" y="8" width="4" height="4" fill="#55bbff"/>
              <g class="vox-debris">
                <rect x="4" y="4" width="4" height="4" fill="#ff5544"/>
                <rect x="40" y="0" width="4" height="4" fill="#44aaff"/>
                <rect x="40" y="36" width="4" height="4" fill="#ff5544"/>
                <rect x="0" y="32" width="4" height="4" fill="#44aaff"/>
              </g>
            </svg>
          </div>
          <p class="feature-label">Woksylowy RTS</p>
          <p class="feature-text">Każdy statek, asteroida i budowla zbudowana z wokseli — i nic nie jest tylko tłem. Statki rozpadają się, asteroidy pękają, szczątki dryfują. Pole bitwy zmienia się w trakcie walki.</p>
        </div>

        <!-- 2. Retro Arcade -->
        <div class="feature-item">
          <div class="feature-icon" aria-hidden="true">
            <svg class="ficon ficon--arcade" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <g fill="#44aaff">
                <rect x="8" y="4" width="4" height="4"/>
                <rect x="36" y="4" width="4" height="4"/>
                <rect x="12" y="8" width="4" height="4"/>
                <rect x="32" y="8" width="4" height="4"/>
                <rect x="12" y="12" width="24" height="4"/>
                <rect x="8" y="16" width="32" height="4"/>
                <rect x="4" y="20" width="40" height="4"/>
                <rect x="4" y="24" width="40" height="4"/>
                <rect x="4" y="28" width="8" height="4"/>
                <rect x="16" y="28" width="4" height="4"/>
                <rect x="28" y="28" width="4" height="4"/>
                <rect x="36" y="28" width="8" height="4"/>
                <rect x="8" y="32" width="4" height="4"/>
                <rect x="36" y="32" width="4" height="4"/>
              </g>
              <rect x="16" y="20" width="4" height="4" fill="#0c0c22"/>
              <rect x="28" y="20" width="4" height="4" fill="#0c0c22"/>
              <rect class="invader-eye" x="16" y="20" width="4" height="4" fill="#ff5544" opacity="0.8"/>
              <rect class="invader-eye" x="28" y="20" width="4" height="4" fill="#ff5544" opacity="0.8"/>
            </svg>
          </div>
          <p class="feature-label">Retro Arcade z Nowoczesnym Twistem</p>
          <p class="feature-text">Oldschoolowa pikselowa energia połączona z nowoczesnym renderowaniem i mechaniką. Ma czuć się znajomo, ale wyglądać jak nic innego.</p>
        </div>

        <!-- 3. Radar -->
        <div class="feature-item">
          <div class="feature-icon" aria-hidden="true">
            <svg class="ficon ficon--radar" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <g fill="#1a4466">
                <rect x="8" y="0" width="32" height="4"/>
                <rect x="4" y="4" width="4" height="4"/>
                <rect x="40" y="4" width="4" height="4"/>
                <rect x="0" y="8" width="4" height="28"/>
                <rect x="44" y="8" width="4" height="28"/>
                <rect x="4" y="36" width="4" height="4"/>
                <rect x="40" y="36" width="4" height="4"/>
                <rect x="8" y="40" width="32" height="4"/>
              </g>
              <rect x="8" y="8" width="32" height="28" fill="#0a1a2a"/>
              <rect x="22" y="8" width="4" height="28" fill="#1a3344" opacity="0.6"/>
              <rect x="8" y="20" width="32" height="4" fill="#1a3344" opacity="0.6"/>
              <rect x="22" y="20" width="4" height="4" fill="#44aaff"/>
              <g class="radar-sweep-px">
                <rect x="22" y="8" width="4" height="4" fill="#44aaff" opacity="0.8"/>
                <rect x="26" y="12" width="4" height="4" fill="#44aaff" opacity="0.6"/>
                <rect x="30" y="16" width="4" height="4" fill="#44aaff" opacity="0.4"/>
              </g>
              <rect class="radar-blip1" x="14" y="12" width="4" height="4" fill="#ff5544"/>
              <rect class="radar-blip2" x="30" y="28" width="4" height="4" fill="#44aaff"/>
            </svg>
          </div>
          <p class="feature-label">Mechaniki Radaru na Dużą Skalę</p>
          <p class="feature-text">Mgła wojny, zasięgi sensorów, martwe strefy. Informacja to potęga — a jej utrata powinna boleć.</p>
        </div>

        <!-- 4. System Międzygalaktyczny -->
        <div class="feature-item">
          <div class="feature-icon" aria-hidden="true">
            <svg class="ficon ficon--hyper" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <g fill="#44aaff">
                <rect x="0" y="4" width="4" height="4"/>
                <rect x="0" y="8" width="4" height="4"/>
                <rect x="0" y="12" width="4" height="4"/>
                <rect x="0" y="16" width="4" height="4"/>
                <rect x="0" y="20" width="4" height="4"/>
                <rect x="0" y="24" width="4" height="4"/>
                <rect x="0" y="28" width="4" height="4"/>
                <rect x="0" y="32" width="4" height="4"/>
                <rect x="4" y="0" width="4" height="4"/>
                <rect x="4" y="36" width="4" height="4"/>
              </g>
              <g fill="#44aaff">
                <rect x="44" y="4" width="4" height="4"/>
                <rect x="44" y="8" width="4" height="4"/>
                <rect x="44" y="12" width="4" height="4"/>
                <rect x="44" y="16" width="4" height="4"/>
                <rect x="44" y="20" width="4" height="4"/>
                <rect x="44" y="24" width="4" height="4"/>
                <rect x="44" y="28" width="4" height="4"/>
                <rect x="44" y="32" width="4" height="4"/>
                <rect x="40" y="0" width="4" height="4"/>
                <rect x="40" y="36" width="4" height="4"/>
              </g>
              <g class="hyper-streaks">
                <rect x="8" y="8" width="8" height="4" fill="#44aaff" opacity="0.6"/>
                <rect x="12" y="16" width="12" height="4" fill="#44aaff" opacity="0.4"/>
                <rect x="16" y="24" width="16" height="4" fill="#44aaff" opacity="0.3"/>
                <rect x="28" y="12" width="8" height="4" fill="#44aaff" opacity="0.5"/>
                <rect x="24" y="28" width="12" height="4" fill="#44aaff" opacity="0.35"/>
              </g>
              <g class="hyper-ship">
                <rect x="20" y="18" width="8" height="4" fill="#fff"/>
                <rect x="18" y="22" width="4" height="4" fill="#ff5544" opacity="0.7"/>
                <rect x="26" y="22" width="4" height="4" fill="#ff5544" opacity="0.7"/>
              </g>
            </svg>
          </div>
          <p class="feature-label">System Międzygalaktyczny</p>
          <p class="feature-text">Skoki hiperkosmiczne między układami gwiezdnymi. Przemieść całą flotę przez galaktyki — strategia na ogromną skalę.</p>
        </div>

        <!-- 5. Multiplayer -->
        <div class="feature-item">
          <div class="feature-icon" aria-hidden="true">
            <svg class="ficon ficon--multi" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <g fill="#44aaff">
                <rect x="4" y="4" width="8" height="4"/>
                <rect x="4" y="8" width="8" height="4"/>
                <rect x="0" y="16" width="16" height="4"/>
                <rect x="0" y="20" width="16" height="4"/>
                <rect x="0" y="24" width="16" height="4"/>
                <rect x="2" y="28" width="12" height="4"/>
              </g>
              <g fill="#ff5544">
                <rect x="36" y="4" width="8" height="4"/>
                <rect x="36" y="8" width="8" height="4"/>
                <rect x="32" y="16" width="16" height="4"/>
                <rect x="32" y="20" width="16" height="4"/>
                <rect x="32" y="24" width="16" height="4"/>
                <rect x="34" y="28" width="12" height="4"/>
              </g>
              <g class="mp-clash">
                <rect x="18" y="12" width="4" height="4" fill="#fff"/>
                <rect x="22" y="16" width="4" height="4" fill="#fff"/>
                <rect x="26" y="12" width="4" height="4" fill="#fff"/>
              </g>
            </svg>
          </div>
          <p class="feature-label">Multiplayer</p>
          <p class="feature-text">Budowany z myślą o innych graczach od samego początku. Celem jest prawdziwa rywalizacja, nie tylko potyczki z botami.</p>
        </div>

        <!-- 6. Wygląd i Odczucie -->
        <div class="feature-item">
          <div class="feature-icon" aria-hidden="true">
            <svg class="ficon ficon--look" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
              <g fill="#44aaff">
                <rect x="20" y="0" width="8" height="4"/>
                <rect x="16" y="4" width="16" height="4"/>
                <rect x="12" y="8" width="24" height="4"/>
                <rect x="8" y="12" width="32" height="4"/>
                <rect x="12" y="16" width="24" height="4"/>
                <rect x="16" y="20" width="16" height="4"/>
                <rect x="16" y="24" width="16" height="4"/>
                <rect x="20" y="28" width="8" height="4"/>
                <rect x="20" y="32" width="8" height="4"/>
                <rect x="22" y="36" width="4" height="4"/>
              </g>
              <rect x="28" y="8" width="8" height="4" fill="#1a6699"/>
              <rect x="32" y="12" width="8" height="4" fill="#1a6699"/>
              <rect x="28" y="16" width="12" height="4" fill="#1a6699"/>
              <rect x="24" y="20" width="8" height="4" fill="#1a6699"/>
              <rect x="24" y="24" width="8" height="4" fill="#1a6699"/>
              <rect x="24" y="28" width="4" height="4" fill="#1a6699"/>
              <rect x="24" y="32" width="4" height="4" fill="#1a6699"/>
              <rect x="16" y="4" width="4" height="4" fill="#66ccff"/>
              <rect x="12" y="8" width="4" height="4" fill="#66ccff"/>
              <rect class="gem-spark" x="4" y="4" width="4" height="4" fill="#fff"/>
              <rect class="gem-spark2" x="40" y="24" width="4" height="4" fill="#fff" opacity="0.6"/>
            </svg>
          </div>
          <p class="feature-label">Wygląd i Odczucie na Pierwszym Miejscu</p>
          <p class="feature-text">To, jak gra się czuje podczas zabawy i jak wygląda w ruchu, ma znaczenie równie duże jak systemy pod spodem. Styl to nie opcja.</p>
        </div>

      </div>
    </section>

    <hr class="scanline" />

    <!-- Ostatni wpis devlog ------------------------------>
    {latestDevlog && (
      <section>
        <div class="section-header">
          <h2>// Najnowszy devlog</h2>
          <a href={`${base}/pl/devlog/`}>{"Wszystkie wpisy >"}</a>
        </div>
        <div class="card-list">
          <a href={`${base}/pl/devlog/${latestDevlog.id.replace(/\.md$/, '')}/`} class="card">
            <div class="card-meta">
              <span>{formatDate(latestDevlog.data.date)}</span>
              {latestDevlog.data.version && (
                <span class="card-version">{latestDevlog.data.version}</span>
              )}
            </div>
            <p class="card-title">{latestDevlog.data.title}</p>
            <p class="card-summary">{latestDevlog.data.summary}</p>
          </a>
        </div>
      </section>
    )}

    <hr class="scanline" />

    <!-- Ostatni artykuł aktualności -------------------->
    {latestNews && (
      <section>
        <div class="section-header">
          <h2>// Najnowsze aktualności</h2>
          <a href={`${base}/pl/news/`}>{"Wszystkie artykuły >"}</a>
        </div>
        <div class="card-list card-list--grid">
          <a href={`${base}/pl/news/${latestNews.id.replace(/\.md$/, '')}/`} class="card">
            {latestNews.data.heroImage && (
              <img
                src={`${base}/images/${latestNews.data.heroImage}`}
                alt={latestNews.data.title}
                class="card-thumbnail"
              />
            )}
            <div class="card-meta">
              <span>{formatDate(latestNews.data.date)}</span>
            </div>
            <p class="card-title">{latestNews.data.title}</p>
            <p class="card-summary">{latestNews.data.summary}</p>
          </a>
        </div>
      </section>
    )}

    <hr class="scanline" />

    <!-- Kontakt i Wsparcie ------------------------------>
    <section class="contact-home">
      <div class="contact-home-inner">
        <div class="contact-home-header">
          <h2 class="contact-home-title">// Kontakt i Wsparcie</h2>
          <p class="contact-home-sub">Projekt solowego developera. Budowany od podstaw. Każda opinia i każde wsparcie ma znaczenie.</p>
        </div>
        <div class="contact-home-grid">
          <!-- Kontakt -->
          <div class="contact-home-card contact-home-card--msg">
            <div class="contact-home-card-icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" width="40" height="40" xmlns="http://www.w3.org/2000/svg">
                <g fill="#44aaff">
                  <rect x="0" y="8" width="48" height="4"/>
                  <rect x="0" y="12" width="4" height="24"/>
                  <rect x="44" y="12" width="4" height="24"/>
                  <rect x="0" y="36" width="48" height="4"/>
                  <rect x="4" y="12" width="4" height="4"/>
                  <rect x="40" y="12" width="4" height="4"/>
                  <rect x="8" y="16" width="4" height="4"/>
                  <rect x="36" y="16" width="4" height="4"/>
                  <rect x="12" y="20" width="4" height="4"/>
                  <rect x="32" y="20" width="4" height="4"/>
                  <rect x="16" y="24" width="4" height="4"/>
                  <rect x="28" y="24" width="4" height="4"/>
                  <rect x="20" y="28" width="8" height="4"/>
                </g>
              </svg>
            </div>
            <h3>Napisz do Mnie</h3>
            <p>Opinie, pomysły, błędy, albo po prostu chcesz się przywitać.</p>
            <div class="contact-home-info">
              <span class="contact-home-name">Slawek</span>
              <a href="mailto:labienusX@gmail.com" class="contact-email">labienusX@gmail.com</a>
            </div>
          </div>
          <!-- Wsparcie -->
          <div class="contact-home-card contact-home-card--support">
            <div class="contact-home-card-icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" width="40" height="40" xmlns="http://www.w3.org/2000/svg">
                <g fill="#ff5544">
                  <rect x="8" y="8" width="4" height="4"/>
                  <rect x="28" y="8" width="4" height="4"/>
                  <rect x="4" y="12" width="12" height="4"/>
                  <rect x="24" y="12" width="12" height="4"/>
                  <rect x="4" y="16" width="36" height="4"/>
                  <rect x="4" y="20" width="36" height="4"/>
                  <rect x="8" y="24" width="28" height="4"/>
                  <rect x="12" y="28" width="20" height="4"/>
                  <rect x="16" y="32" width="12" height="4"/>
                  <rect x="20" y="36" width="4" height="4"/>
                </g>
              </svg>
            </div>
            <h3>Wesprzyj Projekt</h3>
            <p>Pomóż utrzymać momentum. Każde wsparcie ma ogromne znaczenie.</p>
            <a href="https://www.paypal.com/ncp/payment/AWYDN7ZAMM4JJ" target="_blank" rel="noopener" class="paypal-btn">
              Wesprzyj przez PayPal
            </a>
          </div>
        </div>
      </div>
    </section>
  </div>

</BaseLayout>
